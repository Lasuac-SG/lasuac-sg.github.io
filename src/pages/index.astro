---
import BaseLayout from "../layouts/BaseLayout.astro";
import PostList from '../components/PostList.astro';
import {getCollection} from 'astro:content'

const allPosts = await getCollection('blog');

const randomPosts = [...allPosts]
    .sort(() => Math.random() - 0.5)
    .slice(0, 5);
---

<BaseLayout pageTitle="Home">
    <h1>Where Is My Mind</h1>
    <p class="text-lg">Hi!欢迎来到我的博客</p>
    <p class="text-lg">正在建设&更新文章中</p>
    <p class="text-lg">欢迎提出任何建议！</p>

    <section style="margin-top: 50px;">
        <h2 style="font-size: 1.5rem; margin-bottom: 20px; border-bottom: 1px solid #7FB9CE; padding-bottom: 10px;">
            Random posts:
        </h2>
    
        <PostList posts={randomPosts} />
    
  </section>
</BaseLayout>
